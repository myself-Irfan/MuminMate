# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MASKING_KEYS=password,authorization,token,secret,cookie

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=muminmate
DB_PASSWORD=muminmate
DB_HOST=localhost
DB_PORT=5432
DB_NAME=muminmate
TEST_DATABASE_URL=postgresql+asyncpg://muminmate:muminmate@localhost:5432/muminmate_test

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Tokens ────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Threads / Cache ───────────────────────────────────────────────────────────
THREAD_EXPIRY_DAYS=30
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_EXPIRY_DAYS=90

# ── Cleanup ───────────────────────────────────────────────────────────────────
CLEANUP_INTERVAL_HOURS=24
LOGIN_ATTEMPT_RETAIN_HOURS=24

# ── Rate limiting / Lockout ───────────────────────────────────────────────────
LOGIN_ATTEMPT_WINDOW_MINUTES=15
LOGIN_ATTEMPT_MAX_FAILURES=5
REGISTER_COUNT_IN_MINUTES=300
LOGIN_COUNT_IN_MINUTES=10
REFRESH_COUNT_IN_MINUTES=600
RATE_LIMIT_THREADS_CREATE_COUNT=30
RATE_LIMIT_DEFAULT_PER_MINUTE_COUNT=100
RATE_LIMIT_DEFAULT_PER_HOUR_COUNT=1000
RATE_LIMIT_DEFAULT_PER_DAY_COUNT=5000